# === Python関連 ===
.venv/
__pycache__/
*.py[cod]
*$py.class

# === 環境変数・機密情報 ===
# python-dotenvで使用する設定ファイル（パスワード等を入れるため絶対アップしない）
.env

# === ログ・一時ファイル ===
# SKYSEA対策やデバッグ用のログ
logs/
*.log

# === OS・エディタ関連 ===
.vscode/
.idea/
Thumbs.db
.DS_Store

# === Office一時ファイル ===
# ExcelやAccessを開いたときに生成される一時ファイル（~$...）
~$*
*.tmp
*.laccdb

# === プロジェクト固有の除外 ===
# エクスポート元のバイナリファイル自体をバックアップから除外する場合
# （コードのみを管理対象とし、重いxlsm/accdb自体は上げない設定）
# *.xlsm
# *.accdb

# サンプルデータ（レコード内容）はGitHubに上げない
**/samples/
**/table_values/
